---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  publishedDate?: string;
  schema?: object | object[];
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  ogType = 'website',
  publishedDate,
  schema
} = Astro.props;

const fullTitle = title.includes('LitRPG Critic') ? title : `${title} | LitRPG Critic`;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="msvalidate.01" content="7EE57625642C0FDAD06C3D07915EBF09" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="LitRPG Critic" />
  {ogType === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate} />}
  {ogType === 'article' && <meta property="article:author" content="LitRPG Critic" />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <!-- Author & Citation -->
  <meta name="author" content="Pivot Press Publishing" />
  <meta name="citation_title" content={fullTitle} />
  <meta name="citation_author" content="LitRPG Critic" />
  {publishedDate && <meta name="citation_publication_date" content={publishedDate} />}

  <!-- Sitemap & RSS -->
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="LitRPG Critic" href="/rss.xml" />

  <!-- Sister Sites -->
  <link rel="alternate" type="application/rss+xml" title="HaremLit Guide" href="https://haremlitguide.com/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title="Fantasy Ranked" href="https://fantasyranked.com/rss.xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Plausible Analytics -->
  <script async src="https://plausible.io/js/pa-JqwU4slIe-Luwi-mjmm2I.js"></script>
  <script>
    window.plausible=window.plausible||function(){(window.plausible.q=window.plausible.q||[]).push(arguments)};
  </script>

  <!-- JSON-LD Schema -->
  {schemas.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  <!-- Additional head content (e.g. extra JSON-LD schemas) -->
  <slot name="head-extra" />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Nav -->
  <header class="border-b border-[var(--color-border)] sticky top-0 z-50 bg-[var(--color-surface)]/95 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg tracking-tight">
        <span class="text-[var(--color-brand)]">LitRPG</span><span class="text-white">Critic</span>
      </a>
      <nav class="hidden sm:flex items-center gap-6 text-sm text-[var(--color-text-muted)]">
        <a href="/lists/" class="hover:text-white transition-colors">Lists</a>
        <a href="/blog/" class="hover:text-white transition-colors">Reviews</a>
        <a href="/new-releases/" class="hover:text-white transition-colors">New Releases</a>
        <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
        <a href="/about/" class="hover:text-white transition-colors">About</a>
        <a href="https://litrpgtools.com" target="_blank" rel="noopener" class="ml-2 px-3 py-1.5 text-xs font-semibold rounded bg-[var(--color-brand)] text-white hover:opacity-90 transition-opacity">Explore LitRPGTools &rarr;</a>
      </nav>
      <button id="mobile-menu-btn" class="sm:hidden text-[var(--color-text-muted)]" aria-label="Open menu">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] hidden">
    <div id="mobile-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div class="absolute right-0 top-0 h-full w-64 bg-[var(--color-surface)] border-l border-[var(--color-border)] p-6 flex flex-col">
      <button id="mobile-close" class="self-end text-[var(--color-text-muted)] hover:text-white mb-6" aria-label="Close menu">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
        </svg>
      </button>
      <nav class="flex flex-col gap-4 text-sm text-[var(--color-text-muted)]">
        <a href="/lists/" class="hover:text-white transition-colors">Lists</a>
        <a href="/blog/" class="hover:text-white transition-colors">Reviews</a>
        <a href="/new-releases/" class="hover:text-white transition-colors">New Releases</a>
        <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
        <a href="/about/" class="hover:text-white transition-colors">About</a>
      </nav>
      <div class="mt-auto pt-6 border-t border-[var(--color-border)]">
        <a href="https://litrpgtools.com" target="_blank" rel="noopener" class="block text-center px-4 py-2 text-sm font-semibold rounded bg-[var(--color-brand)] text-white hover:opacity-90 transition-opacity">Explore LitRPGTools &rarr;</a>
      </div>
    </div>
  </div>

  <!-- Main -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] mt-16 py-10 text-[var(--color-text-muted)] text-sm">
    <div class="max-w-5xl mx-auto px-4 flex flex-col sm:flex-row justify-between gap-6">
      <div>
        <p class="font-semibold text-white mb-1">
          <span class="text-[var(--color-brand)]">LitRPG</span>Critic
        </p>
        <p class="max-w-xs">Editorial rankings and reviews for LitRPG &amp; progression fantasy readers.</p>
        <p class="mt-2">
          A <a href="https://litrpgtools.com" target="_blank" rel="noopener" class="hover:text-white transition-colors underline">Pivot Press</a> editorial project.
        </p>
      </div>
      <div class="flex gap-10">
        <nav class="flex flex-col gap-1">
          <p class="text-white font-semibold mb-1">Site</p>
          <a href="/lists/" class="hover:text-white transition-colors">Lists</a>
          <a href="/new-releases/" class="hover:text-white transition-colors">New Releases</a>
          <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
        </nav>
        <nav class="flex flex-col gap-1">
          <p class="text-white font-semibold mb-1">Info</p>
          <a href="/about/" class="hover:text-white transition-colors">About</a>
          <a href="/contact/" class="hover:text-white transition-colors">Contact</a>
          <a href="/privacy/" class="hover:text-white transition-colors">Privacy</a>
          <a href="/rss.xml" class="hover:text-white transition-colors">RSS</a>
        </nav>
        <nav class="flex flex-col gap-1">
          <p class="text-white font-semibold mb-1">Our Sites</p>
          <a href="https://litrpgtools.com" target="_blank" rel="noopener me" class="hover:text-white transition-colors">LitRPGTools.com</a>
          <a href="https://haremlitguide.com" target="_blank" rel="noopener me" class="hover:text-white transition-colors">HaremLit Guide</a>
          <a href="https://fantasyranked.com" target="_blank" rel="noopener me" class="hover:text-white transition-colors">Fantasy Ranked</a>
        </nav>
      </div>
    </div>
    <div class="max-w-5xl mx-auto px-4 mt-6 pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row gap-3 justify-between">
      <p>Book data sourced from <a href="https://litrpgtools.com" class="hover:text-white underline" target="_blank" rel="noopener">LitRPGTools.com</a>. Amazon links may be affiliate links.</p>
      <p>&copy; {new Date().getFullYear()} Pivot Press Publishing</p>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-close');
    const backdrop = document.getElementById('mobile-backdrop');
    function openMenu() { menu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
    function closeMenu() { menu?.classList.add('hidden'); document.body.style.overflow = ''; }
    btn?.addEventListener('click', openMenu);
    close?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
  </script>
</body>
</html>

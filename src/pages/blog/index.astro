---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const today = new Date().toISOString().slice(0, 10);
const posts = (await getCollection('blog'))
  .filter(p => p.data.date <= today)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout
  title="LitRPG Blog — Reviews, Lists & News"
  description="All posts from LitRPG Critic — ranked lists, series reviews, and new release coverage."
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-white mb-8">All Posts</h1>
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id.replace(/\.md$/, '')}
            date={post.data.date}
            type={post.data.type}
          />
        ))}
      </div>
    ) : (
      <p class="text-[#666]">No posts yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>

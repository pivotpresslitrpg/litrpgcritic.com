---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — LitRPG Critic"
  description="Get in touch with the LitRPG Critic team."
>
  <div class="max-w-xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-4">Contact</h1>
    <p class="text-[#888] mb-8">Have a book suggestion, correction, or question? Drop us a message.</p>
    <form
      action="https://formspree.io/f/placeholder"
      method="POST"
      class="space-y-4"
    >
      <div>
        <label class="block text-sm text-[#888] mb-1" for="name">Name</label>
        <input
          id="name" name="name" type="text" required
          class="w-full bg-[#1a1a1a] border border-[#2e2e2e] rounded px-3 py-2 text-white focus:outline-none focus:border-[#e85d2f]"
        />
      </div>
      <div>
        <label class="block text-sm text-[#888] mb-1" for="email">Email</label>
        <input
          id="email" name="email" type="email" required
          class="w-full bg-[#1a1a1a] border border-[#2e2e2e] rounded px-3 py-2 text-white focus:outline-none focus:border-[#e85d2f]"
        />
      </div>
      <div>
        <label class="block text-sm text-[#888] mb-1" for="message">Message</label>
        <textarea
          id="message" name="message" rows="5" required
          class="w-full bg-[#1a1a1a] border border-[#2e2e2e] rounded px-3 py-2 text-white focus:outline-none focus:border-[#e85d2f]"
        ></textarea>
      </div>
      <button type="submit" class="bg-[#e85d2f] hover:bg-[#c44a1f] text-white px-5 py-2.5 rounded font-medium transition-colors">
        Send Message
      </button>
    </form>
  </div>
</BaseLayout>

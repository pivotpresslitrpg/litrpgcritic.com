---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — LitRPG Critic"
  description="Get in touch with the LitRPG Critic team."
>
  <div class="max-w-xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-4">Contact</h1>
    <p class="text-[#888] mb-6">Have a book suggestion, correction, or question? We'd love to hear from you.</p>
    <p class="text-[#ccc]">
      Email us at
      <a href="mailto:hello@litrpgcritic.com" class="text-[#e85d2f] hover:underline">hello@litrpgcritic.com</a>
    </p>
  </div>
</BaseLayout>

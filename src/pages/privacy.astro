---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy — LitRPG Critic"
  description="Privacy policy for LitRPGCritic.com"
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-6">Privacy Policy</h1>
    <div class="prose">
      <p>Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h2>Analytics</h2>
      <p>
        This site uses <a href="https://plausible.io" target="_blank" rel="noopener">Plausible Analytics</a>,
        a privacy-friendly analytics tool that does not use cookies and does not collect personal data.
        No tracking across sites. No persistent identifiers.
      </p>
      <h2>Affiliate Links</h2>
      <p>
        Some links to Amazon on this site are affiliate links. If you click through and make a purchase,
        we may earn a small commission at no extra cost to you.
      </p>
      <h2>Cookies</h2>
      <p>This site does not use cookies for tracking or advertising purposes.</p>
      <h2>Contact</h2>
      <p>Questions about this policy? <a href="/contact">Contact us</a>.</p>
    </div>
  </div>
</BaseLayout>

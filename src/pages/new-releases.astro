---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import { getRecentBooks } from '../lib/api';

const books = await getRecentBooks(60, 100);
const thisMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`New LitRPG Releases — ${thisMonth}`}
  description={`The latest LitRPG and progression fantasy releases added to our database. Updated regularly.`}
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <p class="text-sm font-semibold text-[#e85d2f] uppercase tracking-wider mb-2">New Releases</p>
    <h1 class="text-3xl font-bold text-white mb-2">Latest LitRPG &amp; Progression Fantasy Releases</h1>
    <p class="text-[#888] mb-8">Recently added books, updated regularly from our database of {books.length}+ titles.</p>

    <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg px-4">
      {books.length > 0 ? (
        books.map(book => <BookCard book={book} showDescription={true} />)
      ) : (
        <p class="py-8 text-center text-[#666]">No recent releases found.</p>
      )}
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const thisMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`New LitRPG Releases — ${thisMonth}`}
  description="The latest LitRPG and progression fantasy releases. Browse the full new releases calendar on LitRPGTools.com."
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <p class="text-sm font-semibold text-[#e85d2f] uppercase tracking-wider mb-2">New Releases</p>
    <h1 class="text-3xl font-bold text-white mb-3">Latest LitRPG &amp; Progression Fantasy Releases</h1>
    <p class="text-[#888] mb-10 leading-relaxed">
      New releases are tracked live on <strong class="text-white">LitRPGTools.com</strong> — the full database of LitRPG,
      progression fantasy, dungeon core, system apocalypse, and GameLit releases, updated continuously.
    </p>

    <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-xl p-8 text-center">
      <p class="text-white text-lg font-semibold mb-2">Browse the Full New Releases Calendar</p>
      <p class="text-[#888] text-sm mb-6">
        Filter by subgenre, release date, or series. Hundreds of titles tracked across Amazon, Audible, and Royal Road.
      </p>
      <a
        href="https://litrpgtools.com/new-releases"
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 bg-[#e85d2f] hover:bg-[#c44a1f] text-white font-semibold rounded-lg transition-colors"
      >
        View New Releases on LitRPGTools.com &rarr;
      </a>
    </div>

    <div class="mt-10 grid sm:grid-cols-3 gap-4 text-center">
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">LitRPG</p>
        <p class="text-[#888] text-sm">Game mechanics, stat screens, and leveling systems</p>
      </div>
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">Progression Fantasy</p>
        <p class="text-[#888] text-sm">Power growth and mastery without the HUD</p>
      </div>
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">System Apocalypse</p>
        <p class="text-[#888] text-sm">Earth gains RPG mechanics — and nobody asked for this</p>
      </div>
    </div>
  </div>
</BaseLayout>
